module.exports = "#version 300 es\n\nuniform int u_offset;\n\nin vec2 a_pos;\nin vec2 a_tex_coord;\n\nout highp vec2 v_tex_coord;\n\nvoid main() {\n    float globe_width = 1.;\n    vec2 globe_offset = vec2(globe_width * float(u_offset), 0.);\n\n    gl_Position = projectTile(a_pos.xy + globe_offset);\n    v_tex_coord = a_tex_coord;\n}"
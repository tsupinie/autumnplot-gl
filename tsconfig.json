{
    "compilerOptions": {
        "rootDir": ".",
        "outDir": "./dist/",
        "noImplicitAny": true,
        "sourceMap": true,
        "module": "esnext",
        "target": "es2021",
        "allowJs": true,
        "allowSyntheticDefaultImports": true,
        "moduleResolution": "bundler",
        "resolveJsonModule": true,
        "strict": true,
        "types": ["node", "emscripten"],
        "noUncheckedSideEffectImports": false
    }
}